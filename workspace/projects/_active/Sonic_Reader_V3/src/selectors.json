{
  "chatgpt.com": {
    "output": ".agent-turn .markdown, .prose",
    "exclude": "button, nav, .sr-only"
  },
  "claude.ai": {
    "output": ".font-claude-message, .prose",
    "exclude": "button, .hidden"
  },
  "gemini.google.com": {
    "output": "message-content, .markdown",
    "exclude": "header, footer"
  },
  "perplexity.ai": {
    "output": ".prose, .break-words",
    "exclude": "nav"
  },
  "default": {
    "output": "article, p, h1, h2, h3",
    "min_chars": 50
  }
}
