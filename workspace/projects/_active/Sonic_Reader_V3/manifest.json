{
  "manifest_version": 3,
  "name": "Sonic Reader V3: Overlay",
  "version": "3.0.0",
  "description": "AI-powered screen text scanner and instant TTS injector.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "contextMenus"
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/selectors.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
