{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sonic-reader",
  "version": "0.1.0",
  "identifier": "com.steph.sonic-reader",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "node node_modules\\vite\\bin\\vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sonic Reader",
        "width": 520,
        "height": 650,
        "visible": true,
        "resizable": false,
        "skipTaskbar": false
      },
      {
        "label": "highlighter",
        "title": "Sonic Highlighter",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}