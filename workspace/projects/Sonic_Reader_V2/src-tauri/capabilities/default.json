{
    "identifier": "default",
    "description": "Default capabilities for Sonic Reader V2",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "shell:allow-open",
        "shell:allow-execute",
        "global-shortcut:allow-register",
        "global-shortcut:allow-unregister",
        "global-shortcut:allow-unregister-all",
        "global-shortcut:allow-is-registered"
    ]
}
