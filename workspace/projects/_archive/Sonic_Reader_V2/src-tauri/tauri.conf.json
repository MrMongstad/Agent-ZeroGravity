{
    "productName": "Sonic Reader",
    "version": "2.0.0",
    "identifier": "com.sonicreader.v2",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Sonic Reader",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false,
                "visible": true,
                "transparent": false,
                "decorations": true,
                "alwaysOnTop": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}