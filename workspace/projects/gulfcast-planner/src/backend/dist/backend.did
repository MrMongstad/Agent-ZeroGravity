type Stats = 
 record {
   completed: nat;
   remaining: nat;
   total: nat;
 };
type MilestoneStatus = text;
type MilestoneColor = text;
type Milestone = 
 record {
   color: MilestoneColor;
   date: text;
   description: text;
   id: nat;
   status: MilestoneStatus;
   step: text;
   title: text;
 };
service : {
  addMilestone: (step: text, date: text, title: text, description: text,
   status: text, color: text) -> (nat);
  deleteMilestone: (id: nat) -> (bool);
  getAllMilestones: () -> (vec Milestone) query;
  getMilestone: (id: nat) -> (opt Milestone) query;
  getStats: () -> (Stats) query;
  updateMilestone: (id: nat, step: text, date: text, title: text,
   description: text, status: text, color: text) -> (bool);
}
