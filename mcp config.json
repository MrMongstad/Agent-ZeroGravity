{
  "mcpServers": {
    "gcloud": {
      "command": "npx",
      "args": [
        "-y",
        "@google-cloud/gcloud-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "C:/Users/steph/.gemini/antigravity/01_Core_Engine/credentials.json",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "cloud-storage": {
      "command": "npx",
      "args": [
        "-y",
        "@google-cloud/storage-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "C:/Users/steph/.gemini/antigravity/01_Core_Engine/credentials.json",
        "GEMINI_API_KEY": "AIzaSyBZe_Mym3Wyy60IOTQM0dixb8nSwrNEHf8"
      }
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase"
      ],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_ANON_KEY": "${SUPABASE_ANON_KEY}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}",
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "pinecone": {
      "command": "npx",
      "args": [
        "-y",
        "@pinecone-database/mcp"
      ],
      "env": {
        "PINECONE_API_KEY": "${PINECONE_API_KEY}"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server"
      ],
      "env": {
        "APIFY_TOKEN": "${APIFY_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-perplexity"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "BASE_URL": "https://api.perplexity.ai/chat/completions"
      },
      "disabled": true
    },
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "@suncreation/mcp-google-docs"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "C:/Users/steph/.gemini/antigravity/01_Core_Engine/credentials.json",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "CREDENTIALS_PATH": "C:/Users/steph/.gemini/antigravity/01_Core_Engine/credentials.json",
        "TOKEN_PATH": "C:/Users/steph/.gemini/antigravity/01_Core_Engine/token.json"
      }
    },
    "StitchMCP": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://stitch.googleapis.com/mcp",
        "--header",
        "X-Goog-Api-Key: ${GEMINI_API_KEY}"
      ],
      "env": {}
    },
    "gmp-code-assist": {
      "command": "npx",
      "args": [
        "-y",
        "@googlemaps/code-assist-mcp@latest"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "C:/Users/steph/.gemini/antigravity/01_Core_Engine/credentials.json",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "agentzero": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://agent.wreckwired.com/mcp"
      ],
      "env": {}
    },
    "scratchpad": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/JoshuaOliphant/scratchpad_mcp.git",
        "mcp-server-scratchpad"
      ],
      "env": {}
    }
  }
}
